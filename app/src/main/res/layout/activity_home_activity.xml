<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_1">

<!-- ── ÁREA DE SCROLL ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp">

            <!---->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDesafioDoDia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#4A88A9"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#26FFFFFF"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Linha: Logo -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:id="@+id/llLogo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LIVRER"
                                android:textColor="#222222"
                                android:textSize="24sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SO"
                                android:textColor="#FF7A00"
                                android:textSize="24sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Badge streak -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:cardBackgroundColor="#33FF7A00"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#66FF7A00"
                            app:strokeWidth="1.5dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="11dp"
                                android:paddingVertical="5dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔥"
                                    android:textSize="13sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text="0 dias"
                                    android:textColor="#FF7A00"
                                    android:textSize="12sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </RelativeLayout>

                    <!-- Saudação -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Usuário"
                        android:textColor="#FFFFFF"
                        android:textSize="21sp"
                        android:textStyle="bold"/>

                    <!-- Progresso: anel + barra -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp">
                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/progressCircle"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_gravity="center"
                                android:progress="13"
                                app:indicatorColor="#6BBDA7"
                                app:trackColor="#26FFFFFF"
                                app:trackThickness="6dp"
                                app:indicatorSize="64dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="13%"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meta mensal de leitura"
                                android:textColor="#88FFFFFF"
                                android:textSize="12sp"/>
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:progress="13"
                                app:indicatorColor="#6BBDA7"
                                app:trackColor="#26FFFFFF"
                                app:trackCornerRadius="4dp"
                                app:trackThickness="7dp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Botão Seu Desempenho -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDesempenho"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="14dp"
                        android:text="Seu Desempenho"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#364954"
                        app:cornerRadius="14dp"
                        app:strokeColor="#1FFFFFFF"
                        app:strokeWidth="1.5dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════
                 FRASE MOTIVACIONAL
            ══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#6BBDA7"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❝"
                        android:textColor="#33000000"
                        android:textSize="28sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Estude, ou você será ninguém."
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.3"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--Estou bravo-->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDesafioLista"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#6BBDA7"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1.5dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:id="@+id/llDesafioTexto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Desafio do Dia!"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:shadowColor="#33000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="3"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Gire a roleta de livros"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:text="📚"
                        android:textSize="52sp"
                        android:alpha="0.9"/>

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BIBLIOTECA DE ALEXANDRIA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBiblioteca"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#6BBDA7"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="#14000000"
                app:strokeWidth="1.5dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:id="@+id/llBibTexto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biblioteca de"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:shadowColor="#33000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="3"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alexandria"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:shadowColor="#33000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="3"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Explore o acervo"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:text="🏛️"
                        android:textSize="52sp"
                        android:alpha="0.9"/>

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="4dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Botão nav -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            app:cardBackgroundColor="#1A5698B9"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/btnProfileNav"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="👤  Acessar Perfil"
                android:textColor="#364954"
                android:textStyle="bold"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</RelativeLayout>